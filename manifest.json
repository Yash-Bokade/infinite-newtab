{
  "manifest_version": 3,
  "name": "Home Canvas",
  "version": "1.0.0",
  "description": "An infinite-canvas New Tab dashboard. Create, organize, and automate your personal homepage using interactive nodes, containers, and custom React components.",
  "author": "Cursed",

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "chrome_url_overrides": {
    "newtab": "index.html"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "home-canvas@cursed",
      "strict_min_version": "109.0"
    }
  },

  "permissions": [
    "storage"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },

  "action": {
    "default_title": "Open Home Canvas",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}